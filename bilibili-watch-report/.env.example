# Bilibili login cookies. Keep these private.
BILI_SESSDATA=
BILI_BILI_JCT=
BILI_RATE_LIMIT_SECONDS=0.3

# SMTP settings for the daily email.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=bot@example.com
SMTP_PASSWORD=
SMTP_USE_SSL=true
MAIL_TO=me@example.com
MAIL_FROM=bot@example.com

# Optional AI daily insights. Disabled by default.
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
AI_TIMEOUT_SECONDS=20

# Fail-closed by default. Set to true only after confirming private Pages access.
PUBLISH_PAGES=false
